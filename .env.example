# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# --- Django ---
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Data Paths ---
# Defaults are relative to source_code/ — only set these to override
# BASE_DATA_DIR=/absolute/path/to/your/data/year_2
# CHROMA_DB_PATH=/absolute/path/to/your/chroma
CHROMA_COLLECTION_NAME=multimodal_notes

# --- Ollama ---
OLLAMA_LOCAL_URL=http://localhost:11434        # local embeddings + chat
OLLAMA_BASE_URL=http://localhost:11434         # set to https://api.ollama.com for cloud vision
OLLAMA_API_KEY=                                # only required for Ollama cloud (paid tier)

# --- Models ---
MODEL_VISION_BACKEND=ollama                   # ollama | huggingface
MODEL_VISION=llava:13b                        # ollama tag or HF repo ID
MODEL_EMBEDDING=qwen3-embedding:4B
MODEL_CHAT=gemma3:4b
MODEL_ROUTER=mistral:7b-instruct

# --- Retrieval ---
SIMILARITY_THRESHOLD=0.3                      # cosine similarity cutoff (0.0–1.0)

# --- HuggingFace (only needed when MODEL_VISION_BACKEND=huggingface) ---
HF_TOKEN=hf_your_token_here
